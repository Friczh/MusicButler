PORT=8080
DISCORD_TOKEN=

# Shared secret for the /control WebSocket. Must match Controller's value
# exactly. If unset, /control accepts unauthenticated connections (fine for
# local dev, NOT for a public Render deploy).
CALLBACK_SECRET=

# POT provider now runs INSIDE this container (see Dockerfile/start.sh) —
# defaults to localhost, no separate service/account needed.
POT_PROVIDER_URL=http://127.0.0.1:4416
POT_REFRESH_RETRIES=5
POT_REFRESH_BACKOFF_MS=750
POT_CACHE_TTL_MS=600000

YOUTUBE_COOKIES_BASE64=

MAX_CONCURRENT_STREAMS=1
